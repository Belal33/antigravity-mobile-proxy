/**
 * Scrapes the artifact list directly from the Antigravity IDE's conversation panel.
 *
 * The IDE maintains a "tooltip-artifacts" toggle button in the input toolbar.
 * Clicking it reveals a section headed "Artifacts (N Files for Conversation)"
 * with rows showing artifact names and last-updated timestamps.
 *
 * KEY IMPLEMENTATION NOTES:
 *  - The IDE's React handlers only respond to real browser-level mouse events
 *    (CDP Input.dispatchMouseEvent / Puppeteer page.mouse.click), NOT synthetic
 *    JavaScript dispatchEvent() calls. This is why the scraper uses a multi-phase
 *    approach: evaluate() to get button positions, page.mouse.click() to toggle
 *    the panel, then evaluate() again to read the data.
 *
 *  - When the changes panel is active, the artifact button is hidden via CSS
 *    grid (grid-template-columns: 0fr). The scraper detects this and clicks the
 *    changesOverview button first to deactivate the changes panel, making the
 *    artifact button visible. After reading, it restores the original state.
 *
 *  - Header search is scoped to the gap-8 container to avoid matching <code>
 *    elements in conversation messages that mention "Artifacts (".
 *
 * We filter OUT project context files and only return true artifacts.
 */

import type { ProxyContext } from '../types';
import { logger } from '../logger';
import { withPanelLock } from './changes-lock';

export interface IdeArtifact {
  /** Display name, e.g. "task.md" or "Pricing Blue Cards" */
  name: string;
  /** Raw timestamp text from the IDE, e.g. "Mar 10 11:21 PM" */
  lastUpdated: string | null;
  /** Whether this looks like a file (has an extension) */
  isFile: boolean;
}

export interface IdeArtifactResult {
  /** Total count stated in the section header */
  totalCount: number;
  /** Scraped artifact entries (filtered to true artifacts only) */
  artifacts: IdeArtifact[];
  /** The conversation title at the time of scraping */
  conversationTitle: string | null;
}

/**
 * Checks whether a scraped name is a valid artifact name worth keeping.
 * Rejects:
 *  - Bare extensions like ".ts", ".json", ".md" (no basename before the dot)
 *  - Names with directory paths like "lib/foo.ts" (project source files)
 *  - Well-known project config files
 *  - Empty or whitespace-only names
 */
function isValidArtifactName(name: string): boolean {
  if (!name || !name.trim()) return false;

  // Reject bare extensions: ".ts", ".json", ".md" etc.
  // A valid filename must have at least one character before the dot
  if (/^\.\w+$/.test(name)) return false;

  // Reject names with directory separators — these are project file paths
  if (name.includes('/') || name.includes('\\')) return false;

  // Reject names that look like concatenated filenames (e.g. "test.txt file.md other.ts")
  // These appear when the TreeWalker catches tab bar or breadcrumb text
  if (/\.\w+\s+\S/.test(name) && name.split(/\s+/).length > 1) return false;

  // Reject source code / project files by extension.
  // The IDE lists ALL files the conversation touched (source files it read/edited),
  // but those are NOT artifacts — artifacts are generated documents (.md plans, etc.).
  const dotIdx = name.lastIndexOf('.');
  if (dotIdx > 0) {
    const ext = name.substring(dotIdx).toLowerCase();
    const sourceExtensions = new Set([
      '.ts', '.tsx', '.js', '.jsx', '.mjs', '.cjs',
      '.json', '.lock',
      '.css', '.scss', '.less', '.sass',
      '.html', '.htm',
      '.py', '.pyc', '.pyi',
      '.sh', '.bash', '.zsh', '.bat', '.cmd', '.ps1',
      '.yaml', '.yml', '.toml', '.ini', '.cfg',
      '.svg', '.png', '.jpg', '.jpeg', '.gif', '.ico', '.webp',
      '.woff', '.woff2', '.ttf', '.eot',
      '.map', '.d.ts',
      '.env', '.gitignore', '.npmignore', '.eslintrc',
      '.xml', '.sql', '.graphql', '.gql',
      '.go', '.rs', '.rb', '.java', '.kt', '.swift', '.c', '.cpp', '.h',
      '.vue', '.svelte', '.astro',
    ]);
    if (sourceExtensions.has(ext)) return false;
  }

  // Reject well-known project config files (without standard extensions)
  // Also reject common root-level project documentation files (.md files that aren't artifacts)
  const lower = name.toLowerCase();
  const configFiles = [
    'dockerfile', 'makefile', 'procfile', 'gemfile',
    'rakefile', 'vagrantfile', 'jenkinsfile',
    'readme.md', 'agents.md', 'claude.md', 'contributing.md',
    'license.md', 'changelog.md', 'code_of_conduct.md'
  ];
  if (configFiles.includes(lower)) return false;

  return true;
}

/**
 * Get the list of artifacts from the IDE's conversation panel.
 *
 * Strategy:
 *  1. Check whether the artifact section is already visible.
 *  2. If not, click `[data-tooltip-id="tooltip-artifacts"]` to toggle it open.
 *  3. Read the header count — if 0, return empty immediately.
 *  4. Parse the rows to extract artifact names and timestamps.
 *  5. Filter out project/context files — keep only true artifacts.
 *  6. Close the section again (toggle) to leave the IDE clean.
 */
export async function getIdeArtifacts(ctx: ProxyContext): Promise<IdeArtifactResult> {
  if (!ctx.workbenchPage) {
    logger.info('[IdeArtifacts] No active workbench page.');
    return { totalCount: 0, artifacts: [], conversationTitle: null };
  }

  try {
    return await withPanelLock(async () => {
    const page = ctx.workbenchPage!;

    // ── Phase 1: Detect current state ───────────────────────────────────
    const state = await page.evaluate(() => {
      const panel = document.querySelector('.antigravity-agent-side-panel');
      if (!panel) return { error: 'No agent panel found' } as const;

      // Conversation title — try the known selector first, fallback to header div
      let conversationTitle: string | null = null;
      const titleEl = panel.querySelector('span.font-semibold.text-ide-text-color');
      if (titleEl) {
        conversationTitle = titleEl.textContent?.trim() || null;
      } else {
        // Fallback: look for the conversation title div in the header area
        const headerDiv = panel.querySelector('.flex.min-w-0.items-center.overflow-hidden.text-ellipsis.whitespace-nowrap.gap-1');
        if (headerDiv) conversationTitle = headerDiv.textContent?.trim() || null;
      }

      // Check if artifact section is already open
      const gapContainer = panel.querySelector('.flex.grow.flex-col.justify-start.gap-8');
      let headerAlreadyOpen = false;
      if (gapContainer) {
        for (const el of gapContainer.querySelectorAll('*')) {
          const t = (el.textContent || '').trim();
          if (
            t.startsWith('Artifacts (') &&
            t.includes('Files') &&
            el.children.length <= 3 &&
            el.tagName !== 'CODE' &&
            el.tagName !== 'PRE' &&
            !el.closest('.leading-relaxed')
          ) {
            headerAlreadyOpen = true;
            break;
          }
        }
      }

      // Get artifact button position — find the REAL UI button, not code blocks
      const allBtns = panel.querySelectorAll('[data-tooltip-id="tooltip-artifacts"]');
      let artBtnPos: { x: number; y: number } | null = null;
      for (const el of allBtns) {
        const classes = (el as HTMLElement).className || '';
        if (classes.includes('cursor-pointer') && !el.closest('.leading-relaxed') &&
            !el.closest('code') && !el.closest('pre')) {
          const rect = el.getBoundingClientRect();
          artBtnPos = { x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 };
          break;
        }
      }

      // Check if artifact button is hidden (0fr) due to changes panel
      let artBtnHidden = false;
      let changesBtnPos: { x: number; y: number } | null = null;
      if (artBtnPos) {
        const btn = panel.querySelector('[data-tooltip-id="tooltip-artifacts"]') as HTMLElement;
        if (btn) {
          const grid = btn.closest('[style*="grid-template-columns"]') as HTMLElement;
          if (grid?.style.gridTemplateColumns?.includes('0fr')) {
            artBtnHidden = true;
          }
        }
      }

      // Get changes button position if we need to deactivate it
      if (artBtnHidden) {
        const allChangesBtns = panel.querySelectorAll('[data-tooltip-id="tooltip-changesOverview"]');
        for (const el of allChangesBtns) {
          const classes = (el as HTMLElement).className || '';
          if (classes.includes('cursor-pointer') && !el.closest('.leading-relaxed')) {
            const rect = el.getBoundingClientRect();
            changesBtnPos = { x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 };
            break;
          }
        }
      }

      return {
        conversationTitle,
        headerAlreadyOpen,
        artBtnPos,
        artBtnHidden,
        changesBtnPos,
      };
    });

    if ('error' in state) {
      logger.error(`[IdeArtifacts] ${state.error}`);
      return { totalCount: 0, artifacts: [], conversationTitle: null };
    }

    if (!state.artBtnPos) {
      logger.warn('[IdeArtifacts] No artifact button found');
      return { totalCount: 0, artifacts: [], conversationTitle: state.conversationTitle };
    }

    // ── Phase 2: Open the artifact section if needed ────────────────────
    let didOpen = false;
    let didDeactivateChanges = false;

    if (!state.headerAlreadyOpen) {
      // If the artifact button is hidden, deactivate changes first
      if (state.artBtnHidden && state.changesBtnPos) {
        await page.mouse.click(state.changesBtnPos.x, state.changesBtnPos.y);
        await new Promise(r => setTimeout(r, 800));
        didDeactivateChanges = true;

        // Re-read the artifact button position (it might have moved)
        const newArtPos = await page.evaluate(() => {
          const panel = document.querySelector('.antigravity-agent-side-panel');
          if (!panel) return null;
          const allBtns = panel.querySelectorAll('[data-tooltip-id="tooltip-artifacts"]');
          for (const el of allBtns) {
            const classes = (el as HTMLElement).className || '';
            if (classes.includes('cursor-pointer') && !el.closest('.leading-relaxed')) {
              const rect = el.getBoundingClientRect();
              return { x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 };
            }
          }
          return null;
        });
        if (newArtPos) state.artBtnPos = newArtPos;
      }

      // Click the artifact button
      await page.mouse.click(state.artBtnPos.x, state.artBtnPos.y);
      await new Promise(r => setTimeout(r, 1500));
      didOpen = true;
    }

    // ── Phase 3: Read the artifact data ─────────────────────────────────
    const readResult = await page.evaluate(() => {
      const panel = document.querySelector('.antigravity-agent-side-panel');
      if (!panel) return { error: 'Panel disappeared' } as const;

      const gapContainer = panel.querySelector('.flex.grow.flex-col.justify-start.gap-8');
      if (!gapContainer) return { error: 'No gap container' } as const;

      // Find the artifact header
      let header: Element | null = null;
      for (const el of gapContainer.querySelectorAll('*')) {
        const t = (el.textContent || '').trim();
        if (
          t.startsWith('Artifacts (') &&
          t.includes('Files') &&
          el.children.length <= 3 &&
          el.tagName !== 'CODE' &&
          el.tagName !== 'PRE' &&
          !el.closest('.leading-relaxed')
        ) {
          header = el;
          break;
        }
      }

      if (!header) return { error: 'Artifact section did not appear after clicking' } as const;

      // Parse total count
      const headerText = header.textContent?.trim() || '';
      const countMatch = headerText.match(/Artifacts\s*\((\d+)\s*Files?/i);
      const totalCount = countMatch ? parseInt(countMatch[1], 10) : 0;

      if (totalCount === 0) return { totalCount: 0, artifacts: [] as Array<{ name: string; lastUpdated: string | null }> };

      // Find the section container
      let section = header as HTMLElement;
      for (let i = 0; i < 8; i++) {
        if (!section.parentElement) break;
        section = section.parentElement;
        const text = section.textContent || '';
        if (text.includes('Artifact Name') && text.includes('Last Updated')) break;
      }

      // Extract artifact rows
      const rows = section.querySelectorAll('.flex.w-full.flex-row.items-center.justify-between');
      const artifacts: Array<{ name: string; lastUpdated: string | null }> = [];

      for (const row of rows) {
        const cells = row.children;
        if (cells.length < 2) continue;
        const nameText = (cells[0].textContent || '').trim();
        const dateText = (cells[1].textContent || '').trim();
        if (nameText === 'Artifact Name' || !nameText) continue;
        artifacts.push({ name: nameText, lastUpdated: dateText || null });
      }

      // Fallback: TreeWalker
      if (artifacts.length === 0) {
        const walker = document.createTreeWalker(section, NodeFilter.SHOW_TEXT);
        const allTexts: string[] = [];
        while (walker.nextNode()) {
          const t = walker.currentNode.textContent?.trim();
          if (t && t.length > 0) allTexts.push(t);
        }

        for (let i = 0; i < allTexts.length; i++) {
          const text = allTexts[i];
          if (
            text === 'Artifact Name' || text === 'Last Updated' ||
            text.startsWith('Artifacts (') || text === 'Review Changes'
          ) continue;
          if (/^\.\w+$/.test(text)) continue;

          const dateMatch = text.match(/\(([A-Z][a-z]{2}\s+\d{1,2}\s+\d{1,2}:\d{2}\s*(?:AM|PM)?)\)$/);
          if (dateMatch) {
            const name = text.replace(dateMatch[0], '').trim();
            if (name) artifacts.push({ name, lastUpdated: dateMatch[1] });
          } else if (text.match(/^.+\.(md|json|txt|ts|tsx|js|jsx|css|html|yaml|yml|py|sh)$/)) {
            const nextText = allTexts[i + 1] || '';
            const nextDate = nextText.match(/^[A-Z][a-z]{2}\s+\d{1,2}\s+\d{1,2}:\d{2}/);
            artifacts.push({ name: text, lastUpdated: nextDate ? nextText : null });
            if (nextDate) i++;
          }
        }
      }

      return { totalCount, artifacts };
    });

    // ── Phase 4: Close and restore ──────────────────────────────────────
    if (didOpen && state.artBtnPos) {
      // Re-read the artifact button position (scroll might have changed)
      const closeBtnPos = await page.evaluate(() => {
        const panel = document.querySelector('.antigravity-agent-side-panel');
        if (!panel) return null;
        const allBtns = panel.querySelectorAll('[data-tooltip-id="tooltip-artifacts"]');
        for (const el of allBtns) {
          const classes = (el as HTMLElement).className || '';
          if (classes.includes('cursor-pointer') && !el.closest('.leading-relaxed')) {
            const rect = el.getBoundingClientRect();
            return { x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 };
          }
        }
        return null;
      });
      if (closeBtnPos) {
        await page.mouse.click(closeBtnPos.x, closeBtnPos.y);
        await new Promise(r => setTimeout(r, 300));
      }
    }

    if (didDeactivateChanges && state.changesBtnPos) {
      // Re-read the changes button position
      const restoreBtnPos = await page.evaluate(() => {
        const panel = document.querySelector('.antigravity-agent-side-panel');
        if (!panel) return null;
        const allBtns = panel.querySelectorAll('[data-tooltip-id="tooltip-changesOverview"]');
        for (const el of allBtns) {
          const classes = (el as HTMLElement).className || '';
          if (classes.includes('cursor-pointer') && !el.closest('.leading-relaxed')) {
            const rect = el.getBoundingClientRect();
            return { x: rect.x + rect.width / 2, y: rect.y + rect.height / 2 };
          }
        }
        return null;
      });
      if (restoreBtnPos) {
        await page.mouse.click(restoreBtnPos.x, restoreBtnPos.y);
        await new Promise(r => setTimeout(r, 300));
      }
    }

    // ── Phase 5: Process results ────────────────────────────────────────
    if ('error' in readResult) {
      logger.error(`[IdeArtifacts] ${readResult.error}`);
      return { totalCount: 0, artifacts: [], conversationTitle: state.conversationTitle };
    }

    // Server-side filtering: only keep valid artifact names, deduplicated
    const allScraped = readResult.artifacts || [];
    const seen = new Set<string>();
    const validArtifacts: IdeArtifact[] = [];

    for (const a of allScraped) {
      if (!isValidArtifactName(a.name)) continue;
      if (seen.has(a.name)) continue;
      seen.add(a.name);

      validArtifacts.push({
        name: a.name,
        lastUpdated: a.lastUpdated,
        isFile: /\.\w{1,5}$/.test(a.name),
      });
    }

    logger.info(
      `[IdeArtifacts] Scraped ${allScraped.length} raw entries, kept ${validArtifacts.length} valid artifacts (filtered ${allScraped.length - validArtifacts.length}) for "${state.conversationTitle}"`
    );

    return {
      totalCount: validArtifacts.length,
      artifacts: validArtifacts,
      conversationTitle: state.conversationTitle,
    };
    }); // end withPanelLock
  } catch (err: any) {
    logger.error(`[IdeArtifacts] Error scraping: ${err.message}`);
    return { totalCount: 0, artifacts: [], conversationTitle: null };
  }
}
