{
  "name": "antigravity-mobile-proxy",
  "version": "1.0.0",
  "description": "A web chat proxy for Antigravity IDE with ngrok OAuth tunnel support",
  "keywords": [
    "antigravity",
    "ide",
    "chat",
    "proxy",
    "ngrok"
  ],
  "license": "MIT",
  "bin": {
    "antigravity-mobile-proxy": "bin/cli.js"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    "!.next/standalone/node_modules/typescript/",
    "!.next/standalone/node_modules/@img/",
    "!.next/standalone/node_modules/sharp/",
    "!.next/standalone/scripts/",
    "!.next/standalone/package-lock.json",
    "!.next/standalone/tsconfig.json",
    "!.next/standalone/tsconfig.tsbuildinfo",
    "!.next/standalone/report.md",
    "!.next/standalone/README.md",
    ".next/static/",
    "!.next/static/chunks/*.map",
    "public/",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 5555",
    "build": "NODE_ENV=production next build --webpack",
    "postbuild": "node scripts/patch-next.js",
    "start": "next start -p 5555",
    "tunnel": "node bin/cli.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "NODE_ENV=production npm run build"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@ngrok/ngrok": "^1.7.0",
    "next": "16.1.6",
    "puppeteer-core": "^24.39.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "typescript": "5.9.3"
  }
}
