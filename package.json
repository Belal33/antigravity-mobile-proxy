{
  "name": "antigravity-mobile-proxy",
  "version": "1.1.0",
  "description": "Chat with your Antigravity AI coding agent from any device — mobile proxy with secure ngrok tunnel, real-time streaming, and remote approve/reject",
  "keywords": [
    "antigravity",
    "ide",
    "ai-agent",
    "ai-coding",
    "mobile",
    "remote",
    "chat",
    "proxy",
    "ngrok",
    "cdp",
    "chrome-devtools-protocol",
    "developer-tools",
    "devtools",
    "tunnel",
    "pwa",
    "sse",
    "streaming",
    "vscode",
    "electron",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/Belal33/antigravity-mobile-proxy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Belal33/antigravity-mobile-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/Belal33/antigravity-mobile-proxy/issues"
  },
  "author": "Belal",
  "license": "MIT",
  "bin": {
    "antigravity-mobile-proxy": "bin/cli.js"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    "!.next/standalone/node_modules/typescript/",
    "!.next/standalone/node_modules/@img/",
    "!.next/standalone/node_modules/sharp/",
    "!.next/standalone/scripts/",
    "!.next/standalone/package-lock.json",
    "!.next/standalone/tsconfig.json",
    "!.next/standalone/tsconfig.tsbuildinfo",
    "!.next/standalone/report.md",
    "!.next/standalone/README.md",
    ".next/static/",
    "!.next/static/chunks/*.map",
    "public/",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 5555",
    "build": "NODE_ENV=production next build --webpack",
    "postbuild": "node scripts/patch-next.js",
    "start": "next start -p 5555",
    "tunnel": "node bin/cli.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "NODE_ENV=production npm run build"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@ngrok/ngrok": "^1.7.0",
    "next": "16.1.6",
    "puppeteer-core": "^24.39.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "typescript": "5.9.3"
  }
}
